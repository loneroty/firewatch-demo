rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function ownsPath(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isReportImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isMvpImageSize() {
      return request.resource != null
        && request.resource.size <= 500 * 1024;
    }

    match /reportImages/{userId}/{imageId} {
      allow read: if true;
      allow create: if ownsPath(userId) && isReportImage() && isMvpImageSize();
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
