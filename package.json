{
  "name": "firewatch",
  "version": "0.1.0",
  "private": true,
  "description": "FireWatch crowdsource burning report MVP.",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run build:functions && npm run build:zone-tools && next build --webpack",
    "build:app": "next build --webpack",
    "build:functions": "tsc -p functions/tsconfig.json",
    "build:zone-tools": "tsc -p functions/tsconfig.scripts.json",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit && npm run typecheck:functions && npm run typecheck:zone-tools",
    "typecheck:functions": "tsc -p functions/tsconfig.json --noEmit",
    "typecheck:zone-tools": "tsc -p functions/tsconfig.scripts.json --noEmit",
    "zones:backfill": "npm run build:zone-tools && node functions/lib-scripts/scripts/backfillIncidentZones.js",
    "test": "npm run test:unit && npm run test:rules && npm run test:storage && npm run test:functions",
    "test:unit": "jest --runInBand --config jest.config.cjs",
    "test:rules": "firebase emulators:exec --project firewatch-rules-test --only firestore \"jest --runInBand --config jest.rules.config.cjs\"",
    "test:storage": "firebase emulators:exec --project firewatch-storage-test --only storage \"jest --runInBand --config jest.storage.config.cjs\"",
    "test:functions": "firebase emulators:exec --project firewatch-functions-test --only firestore \"jest --runInBand --config jest.functions.config.cjs\"",
    "test:watch": "jest --watch --config jest.config.cjs"
  },
  "dependencies": {
    "firebase": "12.15.0",
    "leaflet": "1.9.4",
    "leaflet.markercluster": "1.5.3",
    "lucide-react": "1.22.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.6",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "29.5.12",
    "@types/leaflet": "1.9.12",
    "@types/leaflet.markercluster": "1.5.4",
    "@types/node": "20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9",
    "firebase-admin": "13.10.0",
    "firebase-functions": "7.2.5",
    "firebase-tools": "^15.22.3",
    "jest": "29.7.0",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.4",
    "ts-jest": "29.1.5",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "overrides": {
    "postcss": "8.5.10",
    "serialize-javascript": "7.0.6",
    "js-yaml": "4.3.0",
    "@opentelemetry/core": "2.8.0",
    "@google-cloud/firestore": "8.6.0",
    "google-gax": "5.0.7",
    "retry-request": "8.0.3",
    "teeny-request": "10.1.3",
    "gaxios": {
      "uuid": "11.1.1"
    }
  }
}
